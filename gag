local function GetPlantData(obj)
	local model = obj:FindFirstAncestorOfClass("Model")
	if not model then return nil end
	if model:GetAttribute("HarvestablePlant") == true then
		local uuid = model:GetAttribute("Uuid")
		if uuid then return {["Uuid"] = uuid} end
	end
	local uuid = model:GetAttribute("Uuid")
	local index = obj.Parent:GetAttribute("GrowthAnchorIndex")
	if uuid and index then
		return {
			["Uuid"] = uuid,
			["GrowthAnchorIndex"] = index
		}
	end
	local rootModel = model.Parent
	if rootModel and rootModel:IsA("Model") and rootModel:GetAttribute("Uuid") then
		return {
			["Uuid"] = rootModel:GetAttribute("Uuid"),
			["GrowthAnchorIndex"] = model:GetAttribute("GrowthAnchorIndex")
		}
	end
	return nil
end

