MainGroup:AddToggle("AutoPlant", {
	Text = "自动种植 (移动触发)",
	Default = false,
	Callback = function(v)
		_G.AutoPlant = v
		task.spawn(function()
			local PlantRemote = ReplicatedStorage.RemoteEvents.PlantSeed
			while _G.AutoPlant do
				local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
				if root and root.Velocity.Magnitude > 0.1 then
					local p = root.Position - Vector3.new(0, 3, 0)
					for fullName, enabled in pairs(Library.Options.PlantDropdown.Value) do
						if enabled and _G.AutoPlant then
							PlantRemote:InvokeServer(string.gsub(fullName, " Seed", ""), p)
						end
					end
				end
				task.wait(Library.Options.PlantDelay.Value)
			end
		end)
	end
})

MainGroup:AddToggle("AutoPlantAtPos", {
	Text = "定点自动种植 (独立开关)",
	Default = false,
	Callback = function(v)
		_G.AutoPlantAtPos = v
		task.spawn(function()
			local PlantRemote = ReplicatedStorage.RemoteEvents:FindFirstChild("PlantSeed")
			while _G.AutoPlantAtPos do
				local inputStr = Library.Options.CustomPos.Value
				local coords = string.split(inputStr, ",")
				if #coords >= 3 then
					local x = tonumber(coords[1])
					local y = tonumber(coords[2])
					local z = tonumber(coords[3])
					if x and y and z and PlantRemote then
						local targetPos = Vector3.new(x, y, z)
						for fullName, enabled in pairs(Library.Options.PlantDropdown.Value) do
							if enabled and _G.AutoPlantAtPos then
								PlantRemote:InvokeServer(string.gsub(fullName, " Seed", ""), targetPos)
							end
						end
					end
				end
				task.wait(Library.Options.PlantDelay.Value)
			end
		end)
	end
})

