local function smoothTeleport(rootPart, targetCF, duration)
	if not rootPart then return end
	local currentCF = rootPart.CFrame
	local stageDuration = duration / 3
	local upOffset = Vector3.new(0, 50, 0)
	TweenService:Create(rootPart, TweenInfo.new(stageDuration, Enum.EasingStyle.Linear), {CFrame = currentCF + upOffset}):Play()
	task.wait(stageDuration)
	TweenService:Create(rootPart, TweenInfo.new(stageDuration, Enum.EasingStyle.Linear), {CFrame = targetCF + upOffset}):Play()
	task.wait(stageDuration)
	TweenService:Create(rootPart, TweenInfo.new(stageDuration, Enum.EasingStyle.Linear), {CFrame = targetCF}):Play()
	task.wait(stageDuration)
end

