local function getStock(shopType, itemName)
	local guiName = (shopType == "SeedShop") and "SeedShop" or "GearShop"
	local shopGui = lp.PlayerGui:FindFirstChild(guiName)
	if shopGui then
		local scrollFrame = shopGui.Frame:FindFirstChild("ScrollingFrame")
		if scrollFrame then
			for _, item in ipairs(scrollFrame:GetChildren()) do
				local info = item:FindFirstChild("MainInfo")
				if info then
					local label = info:FindFirstChild("SeedName") or info:FindFirstChild("GearName")
					if label and label.Text == itemName then
						local stockText = info:FindFirstChild("StockText")
						if stockText then
							return tonumber(string.match(stockText.Text, "%d+")) or 0
						end
					end
				end
			end
		end
	end
	return 0
end

MainGroup:AddToggle("AutoSell", {
	Text = "自动出售全部",
	Default = false,
	Callback = function(v)
		_G.AutoSell = v
		task.spawn(function()
			while _G.AutoSell do
				local itemCount = 0
				local char = lp.Character
				local backpack = lp:FindFirstChild("Backpack")
				
				local function checkContainer(container)
					if not container then return end
					for _, item in ipairs(container:GetChildren()) do
						if item:IsA("Tool") then
							local isExclude = false
							for _, sName in ipairs(SeedNames) do
								if string.find(item.Name, sName) then isExclude = true break end
							end
							if not isExclude then
								for _, gName in ipairs(GearNames) do
									if item.Name == gName then isExclude = true break end
								end
							end
							if not isExclude then
								itemCount = itemCount + 1
							end
						end
					end
				end

				checkContainer(backpack)
				checkContainer(char)

				if itemCount >= Library.Options.SellThreshold.Value then
					local root = char and char:FindFirstChild("HumanoidRootPart")
					if root then
						local oldCF = root.CFrame
						root.CFrame = CFrame.new(149.4, 204.0, 672.0)
						task.wait(0.5)
						ReplicatedStorage.RemoteEvents.SellItems:InvokeServer("SellAll")
						task.wait(0.3)
						root.CFrame = oldCF
					end
				end
				task.wait(Library.Options.ActionDelay.Value)
			end
		end)
	end
})

