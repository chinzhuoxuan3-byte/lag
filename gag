MainGroup:AddToggle("AutoPlant", {
    Text = "自动种植 (移动触发)",
    Default = false,
    Callback = function(v)
        _G.AutoPlant = v
        task.spawn(function()
            while _G.AutoPlant do
                local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if root and root.Velocity.Magnitude > 0.1 then
                    local p = root.Position - Vector3.new(0, 3, 0)
                    for fullName, enabled in pairs(Library.Options.PlantDropdown.Value) do
                        if enabled and _G.AutoPlant then
                            ReplicatedStorage.RemoteEvents.PlantSeed:InvokeServer(string.gsub(fullName, " Seed", ""), p)
                        end
                    end
                end
                task.wait(math.max(Library.Options.ActionDelay.Value, 0.05))
            end
        end)
    end
})
MainGroup:AddDropdown("PlantDropdown", { Values = SeedNames, Default = 1, Multi = true, Text = "选择种植植物" })

