local function getStock(shopType, itemName)
	local guiName = (shopType == "SeedShop") and "SeedShop" or "GearShop"
	local shopGui = lp.PlayerGui:FindFirstChild(guiName)
	if not shopGui then return 0 end
	local scrollFrame = shopGui:FindFirstChild("Frame") and shopGui.Frame:FindFirstChild("ScrollingFrame")
	if not scrollFrame then return 0 end
	for _, item in ipairs(scrollFrame:GetChildren()) do
		if item:IsA("Frame") and item:GetAttribute("ShopItemName") == itemName then
			local mainInfo = item:FindFirstChild("MainInfo")
			if mainInfo then
				local noStock = mainInfo:FindFirstChild("NoStock")
				if noStock and noStock.Visible == true then return 0 end
				local stockLabel = mainInfo:FindFirstChild("StockText")
				if stockLabel then
					local text = stockLabel.Text
					if text == "NO STOCK" or text == "..." then return 0 end
					return tonumber(string.match(text, "%d+")) or 0
				end
			end
		end
	end
	return 0
end

