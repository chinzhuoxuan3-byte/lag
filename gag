MainGroup:AddToggle("AutoEquipPlant", {
	Text = "自动装备种植",
	Default = false,
	Callback = function(v)
		_G.AutoEquipPlant = v
		task.spawn(function()
			local PlantRemote = ReplicatedStorage.RemoteEvents:FindFirstChild("PlantSeed")
			while _G.AutoEquipPlant do
				local char = lp.Character
				local backpack = lp:FindFirstChild("Backpack")
				local root = char and char:FindFirstChild("HumanoidRootPart")
				if char and backpack and root and PlantRemote then
					for _, itemName in ipairs(SeedNames) do
						if not _G.AutoEquipPlant then break end
						if Library.Options.EquipDropdown.Value[itemName] then
							local itemInBackpack = nil
							for _, item in ipairs(backpack:GetChildren()) do
								if string.find(item.Name, itemName) then
									itemInBackpack = item
									break
								end
							end
							if itemInBackpack then
								itemInBackpack.Parent = char
								task.wait(0.1)
								local angle = math.rad(math.random(0, 360))
								local offset = Vector3.new(math.cos(angle) * 2, -3, math.sin(angle) * 2)
								local plantPos = root.Position + offset
								PlantRemote:InvokeServer(string.gsub(itemName, " Seed", ""), plantPos)
								task.wait(Library.Options.EquipDelay.Value)
								if _G.AutoEquipPlant then
									itemInBackpack.Parent = backpack
								end
							end
						end
					end
				end
				task.wait(0.05)
			end
		end)
	end
})

