task.spawn(function()
	while task.wait(0.5) do
		local SeedScroll = lp.PlayerGui:FindFirstChild("SeedShop") and lp.PlayerGui.SeedShop.Frame:FindFirstChild("ScrollingFrame")
		if SeedScroll then
			for _, item in ipairs(SeedScroll:GetChildren()) do
				local info = item:FindFirstChild("MainInfo")
				if info and info:FindFirstChild("SeedName") then
					local name = info.SeedName.Text
					local stock = tonumber(string.match(info.StockText.Text, "%d+")) or 0
					if SeedLabels[name] then SeedLabels[name]:SetText(name .. ": " .. stock) end
				end
			end
		end

		local GearScroll = lp.PlayerGui:FindFirstChild("GearShop") and lp.PlayerGui.GearShop.Frame:FindFirstChild("ScrollingFrame")
		if GearScroll then
			for _, item in ipairs(GearScroll:GetChildren()) do
				local info = item:FindFirstChild("MainInfo")
				if info and (info:FindFirstChild("GearName") or info:FindFirstChild("SeedName")) then
					local label = info:FindFirstChild("GearName") or info:FindFirstChild("SeedName")
					local stock = tonumber(string.match(info.StockText.Text, "%d+")) or 0
					if GearLabels[label.Text] then GearLabels[label.Text]:SetText(label.Text .. ": " .. stock) end
				end
			end
		end
	end
end)

local function handleAutoBuy(configName, shopType, notifiedTable, dropdownOption)
	if _G[configName] then
		local scrollName = shopType == "SeedShop" and "SeedShop" or "GearShop"
		local Scroll = lp.PlayerGui:FindFirstChild(scrollName) and lp.PlayerGui[scrollName].Frame:FindFirstChild("ScrollingFrame")
		if Scroll then
			for itemName, isSelected in pairs(Library.Options[dropdownOption].Value) do
				if isSelected and _G[configName] then
					local currentStock = -1
					for _, item in ipairs(Scroll:GetChildren()) do
						local info = item:FindFirstChild("MainInfo")
						if info then
							local label = info:FindFirstChild("SeedName") or info:FindFirstChild("GearName")
							if label and label.Text == itemName then
								currentStock = tonumber(string.match(info.StockText.Text, "%d+")) or 0
								break
							end
						end
					end
					if currentStock > 0 then
						PurchaseRemote:InvokeServer(shopType, itemName)
						notifiedTable[itemName] = false
						task.wait(Library.Options.ActionDelay.Value)
					elseif currentStock == 0 and not notifiedTable[itemName] then
						Library:Notify("【" .. itemName .. "】已售罄，等待刷新", 5)
						notifiedTable[itemName] = true
					end
				end
			end
		end
	end
end

task.spawn(function()
	while task.wait() do
		handleAutoBuy("AutoBuySelected", "SeedShop", NotifiedSeeds, "BuyDropdown")
